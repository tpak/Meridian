        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ograni\u010deno na 100 vremenskih zona!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6700\u5927\u3067100\u306e\u6642\u9593\u5e2f\u304c\u8a2d\u5b9a\u53ef\u80fd\u3067\u3059!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dozwolone maksymalnie 100 stref czasowych!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "M\u00e1ximo de fusos hor\u00e1rios permitido: 100!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0420\u0430\u0437\u0440\u0435\u0448\u0435\u043d\u043e \u043c\u0430\u043a\u0441\u0438\u043c\u0443\u043c 100 \u0447\u0430\u0441\u043e\u0432\u044b\u0445 \u043f\u043e\u044f\u0441\u043e\u0432!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "En fazla 100 saat dilimi kabul edilir!"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e 100 \u0447\u0430\u0441\u043e\u0432\u0438\u0445 \u043f\u043e\u044f\u0441\u0456\u0432!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6700\u591a\u5141\u8bb8 100 \u4e2a\u65f6\u533a\uff01"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6700\u591a\u5141\u8a31 100 \u500b\u6642\u5340\uff01"
