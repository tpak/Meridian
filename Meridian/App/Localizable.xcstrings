    "You're offline, maybe?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You\u2019re offline, maybe?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bist Du eventuell offline?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\u00bfQuiz\u00e1s est\u00e1s sin conexi\u00f3n a internet?"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mo\u017eda nema\u0161 vezu s internetom?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30aa\u30d5\u30e9\u30a4\u30f3\u306e\u3088\u3046\u3067\u3059\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub2f9\uc2e0\uc740 \uc624\ud504\ub77c\uc778\uc785\ub2c8\ub2e4. \uc544\ub9c8\ub3c4?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeste\u015b offline (?)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voc\u00ea est\u00e1 offline, talvez?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0412\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0412\u044b \u043d\u0435 \u0432 \u0441\u0435\u0442\u0438?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acaba \u00e7evrimd\u0131\u015f\u0131 m\u0131s\u0131n\u0131z?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u60a8\u5df2\u7ecf\u79bb\u7ebf\uff1f"
          }
        }
      }
    },
    "Try again, maybe?": {
      "localizations": {
        "en": {
          "stringUnit": {
