    "Search Field Placeholder": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a city, state or country name"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0623\u062f\u062e\u0644 \u0627\u0633\u0645 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0623\u0648 \u0627\u0644\u0648\u0644\u0627\u064a\u0629 \u0623\u0648 \u0627\u0644\u0628\u0644\u062f"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebe eine Stadt, ein Bundesland oder Land ein"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduzca un nombre de ciudad, estado o pa\u00eds"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez une ville, une r\u00e9gion ou un pays"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0936\u0939\u0930, \u0930\u093e\u091c\u094d\u092f \u092f\u093e \u0926\u0947\u0936 \u0915\u093e \u0928\u093e\u092e \u0926\u0930\u094d\u091c \u0915\u0930\u0947\u0902"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Upi\u0161i grad, dr\u017eavu ili zemlju"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u90fd\u5e02\u540d\u3001\u5dde\u3084\u770c\u3001\u56fd\u540d\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wprowad\u017a miasto, wojew\u00f3dztwo lub nazw\u0119 kraju"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira uma cidade, estado ou pa\u00eds"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0412\u0432\u0435\u0434\u0438\u0442\u0435 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0433\u043e\u0440\u043e\u0434\u0430, \u0448\u0442\u0430\u0442\u0430 \u0438\u043b\u0438 \u0441\u0442\u0440\u0430\u043d\u044b"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir \u015fehir, b\u00f6lge veya \u00fclke girin"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0412\u0432\u0435\u0434\u0456\u0442\u044c \u043c\u0456\u0441\u0442\u043e, \u043e\u0431\u043b\u0430\u0441\u0442\u044c \u0430\u0431\u043e \u043d\u0430\u0437\u0432\u0443 \u043a\u0440\u0430\u0457\u043d\u0438"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8f93\u5165\u57ce\u5e02\u3001\u7701/\u5dde\u6216\u56fd\u5bb6\u540d\u79f0"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8f38\u5165\u4e00\u500b\u5730\u9ede\u7684\u540d\u7a31"
          }
        }
      }
    },
    "No Timezone Selected": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please select a timezone!"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0631\u062c\u0627\u0621 \u0627\u062e\u062a\u0631 \u0645\u0646\u0637\u0642\u062a\u0643 \u0627\u0644\u0632\u0645\u0646\u064a\u0629!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte w\u00e4hle eine Zeitzone!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\u00a1Por favor, selecciona una zona horaria!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez s\u00e9lectionner un fuseau horaire !"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberi vremensku zonu!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6642\u9593\u5e2f\u3092\u9078\u629e\u3057\u3066\u304f\u3060\u3055\u3044!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz stref\u0119 czasow\u0105!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, selecione um fuso hor\u00e1rio!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0447\u0430\u0441\u043e\u0432\u043e\u0439 \u043f\u043e\u044f\u0441!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "L\u00fctfen saat dilimi se\u00e7in!"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0411\u0443\u0434\u044c \u043b\u0430\u0441\u043a\u0430, \u043e\u0431\u0435\u0440\u0456\u0442\u044c \u0447\u0430\u0441\u043e\u0432\u0438\u0439 \u043f\u043e\u044f\u0441!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8bf7\u9009\u62e9\u4e00\u4e2a\u65f6\u533a\uff01"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8acb\u9078\u53d6\u4e00\u500b\u6642\u5340\uff01"
          }
        }
      }
    },
    "Max Timezones Selected": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maximum 100 timezones allowed!"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0627\u0644\u062d\u062f \u0627\u0644\u0623\u0642\u0635\u0649 \u0627\u0644\u0645\u0633\u0645\u0648\u062d \u0628\u0647 100 \u0645\u0646\u0637\u0642\u0629 \u0632\u0645\u0646\u064a\u0629!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es werden maximal 100 Zeitzonen unterst\u00fctzt!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\u00a1Se permiten m\u00e1ximo 100 zonas horarias!"
